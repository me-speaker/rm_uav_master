# =============================================================================
# rm_ws .gitignore
# =============================================================================
# 源码目录 src/ 里有 vendor 代码 (fast_lio / livox_ros_driver2 / odin_ros_driver)
# 不能直接 .gitignore 整个 src/, 只能屏蔽特定目录.

# ---- colcon 产物 (host 上持久化的 workspace) ----------------------------------
.colcon_ws/
install/
build/
log/

# ---- python 缓存 --------------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# ---- SLAM / 雷达 runtime 产物 -------------------------------------------------
*/Log/
*/PCD/
*/log/
*/doc/results/

# ---- vendor 仓库自带的东西 ----------------------------------------------------
src/odin_ros_driver/.git/
src/odin_ros_driver/log/
src/fast_lio/Log/
src/fast_lio/PCD/

# ---- 编辑器 / 系统临时文件 ----------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
*.tmp
CLAUDE.md

# 编译产物
/dist
