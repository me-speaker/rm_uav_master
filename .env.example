# =============================================================================
# .env.example — docker-compose.dev.yml 默认参数覆写
# =============================================================================
# cp .env.example .env  →  改 .env 里的值覆盖 compose 默认
#
# ⚠️ .env 含敏感信息 (drone IP / lidar IP), 不要 commit 到 git
#    .gitignore 应该 ignore .env (如果没, 加进去)
# =============================================================================

# ============ ROS / mavros 配置 ============

# 雷达类型: odin | mid360
LIDAR=odin

# PX4 MAVLink USB 串口 (/dev/ttyACM0 或 /dev/ttyUSB0)
FCU_URL=/dev/ttyACM0:921600

# Mid-360 IP (Livox 默认 192.168.1.1xx, 后两位随机)
LIVOX_LIDAR_IP=192.168.1.1xx

# ROS 2 网络
ROS_DOMAIN_ID=0
ROS_LOCALHOST_ONLY=0          # 0=允许跨主机 DDS discovery (default), 1=仅 localhost

# ============ 远程 (drone 端) ============
# 部署 / 同步代码用, 不影响 docker-compose 本地 dev
# DRONE_HOST=192.168.100.3
# DRONE_USER=<drone-user>
# DRONE_PASSWORD=<drone password>   # ⚠️ 不要 commit
